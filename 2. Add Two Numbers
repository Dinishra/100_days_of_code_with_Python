# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def addTwoNumbers(self, l1: Optional[ListNode], l2: Optional[ListNode]) -> Optional[ListNode]:
        head = ListNode()
        temp = head
        carry=0
        while l1 or l2 or carry: #we also add carry beacuse the final 1 was never added
            num1 = 0
            num2= 0
            if l1 != None:
                num1 = l1.val 
                l1= l1.next
            if l2!= None: 
                num2 = l2.val
                l2 = l2.next

            sum = num1 + num2 +carry
            carry = sum//10  #gives quotient
            digit=sum%10  # gives remainder
            temp.next= ListNode(digit) # creating new node
            temp = temp.next

        return head.next
            

        
        
